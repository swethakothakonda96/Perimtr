# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# -------------------------------------------------------

# PostgreSQL connection string (required)
# Free option: sign up at https://neon.tech, create a project,
# copy the connection string from the dashboard.
#
# Format:
#   postgres://USER:PASSWORD@HOST:5432/DATABASE
#
# Neon example:
#   DATABASE_URL=postgres://alice:strongpass@ep-abc-123.us-east-2.aws.neon.tech/perimtr?sslmode=require
#
# Local Postgres example:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/perimtr
DATABASE_URL=

# Session signing key — any long random string
SESSION_SECRET=change_me_to_something_long_and_random
